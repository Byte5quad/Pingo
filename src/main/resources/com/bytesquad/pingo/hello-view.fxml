<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bytesquad.pingo.HelloController"
      prefWidth="1200" prefHeight="750"
      styleClass="root"
      stylesheets="@styles.css">

    <VBox styleClass="sidebar" prefWidth="220">
        <HBox styleClass="sidebar-logo" spacing="10">
            <Label text="🏓" styleClass="logo-icon"/>
            <Label text="Pingo" styleClass="logo-text"/>
        </HBox>
        <Label text="VILLAGES" styleClass="sidebar-section-label"/>
        <VBox fx:id="villageList" styleClass="village-list" spacing="2"/>
        <Region VBox.vgrow="ALWAYS"/>
        <VBox styleClass="sidebar-bottom" spacing="8">
            <Separator styleClass="sidebar-divider"/>
            <HBox styleClass="sidebar-user" spacing="10" alignment="CENTER_LEFT">
                <Label text="S" styleClass="user-avatar"/>
                <VBox spacing="2">
                    <Label fx:id="profileNameLabel" text="Username" styleClass="user-name"/>
                    <Label fx:id="profileSubLabel" text="Connecting..." styleClass="user-status"/>
                </VBox>
            </HBox>
        </VBox>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" styleClass="main-content">
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label fx:id="topbarTitle" text="Welcome to Pingo" styleClass="topbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="🔍" styleClass="icon-btn"/>
        </HBox>
        <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" styleClass="content-area"/>
    </VBox>

</HBox>